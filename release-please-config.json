{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schema.json",
  "release-type": "simple",
  "separate-pull-requests": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "packages": {
    ".": {
      "release-type": "simple",
      "version-file": "version.txt",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "api-spec/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "frontend/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "backend/gradle.properties",
          "start": "version=",
          "end": ""
        }
      ]
    }
  }
}
